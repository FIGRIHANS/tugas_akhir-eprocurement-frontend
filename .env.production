# Frontend Production Environment Variables
# Configuration for codeverse.id subdomain setup WITH TRAEFIK

# Production URLs - Subdomain with /api prefix
# Backend controllers use [Route("api/[controller]")]
VITE_API_BASE_URL=https://account-api.codeverse.id/api
VITE_API_GENERAL_BASE_URL=https://api.codeverse.id
VITE_API_VENDOR_BASE_URL=https://vendor-api.codeverse.id
VITE_API_INVOICE_BASE_URL=https://invoice-api.codeverse.id/api

# Local Testing (uncomment for local development)
# VITE_API_BASE_URL=http://localhost:8001/api
# VITE_API_GENERAL_BASE_URL=http://localhost:8002/api
# VITE_API_VENDOR_BASE_URL=http://localhost:8004/api
# VITE_API_INVOICE_BASE_URL=http://localhost:8003/api

# IMPORTANT NOTES:
# 1. These URLs are built into the frontend during 'docker build'
# 2. Backend controllers have [Route("api/[controller]")] prefix
# 3. Full URL example: https://account-api.codeverse.id/api/auth/sign-in
# 4. Traefik routes: account-api.codeverse.id → account-api:8001
# 5. If you change these URLs, rebuild frontend:
#    docker-compose build frontend
#    docker-compose up -d frontend
